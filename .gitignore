# 吉送外卖 - Git忽略文件配置

# ==================== Java / Spring Boot ====================
# 编译输出
jswm-backend/target/
jswm-backend/!.mvn/wrapper/maven-wrapper.jar
jswm-backend/!**/src/main/**/target/
jswm-backend/!**/src/test/**/target/

# IDE - IntelliJ IDEA
jswm-backend/.idea/
jswm-backend/*.iws
jswm-backend/*.iml
jswm-backend/*.ipr

# IDE - Eclipse
jswm-backend/.apt_generated
jswm-backend/.classpath
jswm-backend/.factorypath
jswm-backend/.project
jswm-backend/.settings/
jswm-backend/.springBeans
jswm-backend/.sts4-cache

# IDE - NetBeans
jswm-backend/nbproject/private/
jswm-backend/nbbuild/
jswm-backend/dist/
jswm-backend/nbdist/
jswm-backend/.nb-gradle/

# ==================== Node.js / Vue.js ====================
# 依赖目录
jswm-frontend/node_modules/
jswm-frontend/.pnpm-store/

# 构建输出
jswm-frontend/dist/
jswm-frontend/dist-ssr/
jswm-frontend/*.local

# 日志文件
jswm-frontend/npm-debug.log*
jswm-frontend/yarn-debug.log*
jswm-frontend/yarn-error.log*
jswm-frontend/pnpm-debug.log*

# IDE - VSCode
jswm-frontend/.vscode/*
!jswm-frontend/.vscode/extensions.json
jswm-frontend/.idea/

