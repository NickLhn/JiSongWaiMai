<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jswm.mapper.BizReviewMapper">

    <resultMap id="BaseResultMap" type="com.jswm.entity.BizReview">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="user_id" property="userId"/>
        <result column="merchant_id" property="merchantId"/>
        <result column="dish_id" property="dishId"/>
        <result column="rating" property="rating"/>
        <result column="content" property="content"/>
        <result column="images" property="images"/>
        <result column="is_anonymous" property="isAnonymous"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, order_id, user_id, merchant_id, dish_id, rating, content, images, is_anonymous, create_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM biz_review
        WHERE id = #{id}
    </select>

    <select id="selectByOrderId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM biz_review
        WHERE order_id = #{orderId}
    </select>

    <select id="selectByMerchantId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM biz_review
        WHERE merchant_id = #{merchantId}
        <if test="rating != null">
            AND rating = #{rating}
        </if>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM biz_review
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <insert id="insert" parameterType="com.jswm.entity.BizReview" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO biz_review (order_id, user_id, merchant_id, dish_id, rating, content, images, is_anonymous)
        VALUES (#{orderId}, #{userId}, #{merchantId}, #{dishId}, #{rating}, #{content}, #{images}, #{isAnonymous})
    </insert>

    <delete id="deleteById">
        DELETE FROM biz_review WHERE id = #{id}
    </delete>

    <select id="countByMerchantId" resultType="int">
        SELECT COUNT(*) FROM biz_review WHERE merchant_id = #{merchantId}
    </select>

    <select id="countByRating" resultType="int">
        SELECT COUNT(*) FROM biz_review WHERE merchant_id = #{merchantId} AND rating = #{rating}
    </select>

    <select id="selectAverageRating" resultType="java.math.BigDecimal">
        SELECT AVG(rating) FROM biz_review WHERE merchant_id = #{merchantId}
    </select>

</mapper>
